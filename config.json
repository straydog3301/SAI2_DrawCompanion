{
  "version": 1,
  "language": "zh_TW",
  "theme": "dark",
  "color_scheme": "purple",
  "window_geometry": null,
  "topmost": false,
  "mini_mode": false,
  "tracker": {
    "auto_save_interval": 60,
    "min_tracking_time": 5,
    "auto_group_enabled": true,
    "group_by_folder": false
  },
  "timelapse": {
    "fps": 60,
    "quality": "high",
    "capture_canvas_only": true,
    "output_format": "mp4",
    "ffmpeg_path": null,
    "auto_start": false
  },
  "hotkeys": {
    "start_stop": "F12",
    "toggle_mini": "F11",
    "liquify_helper": "F9",
    "take_screenshot": "F10"
  },
  "charts": {
    "default_view": "day",
    "show_tooltips": true,
    "animation_enabled": true
  },
  "notifications": {
    "enabled": true,
    "sound_enabled": false,
    "show_toast": true
  },
  "advanced": {
    "debug_mode": false,
    "log_level": "INFO",
    "enable_crash_report": true,
    "check_updates": true
  }
}